# rive-config.cmake
# Generated by the rive vcpkg overlay port.
# Provides imported CMake targets for the Rive C++ runtime.
#
# Targets:
#   rive::rive          - core animation runtime  (+ text/layout/audio deps)
#   rive::pls_renderer  - GPU renderer (Metal + OpenGL; links Metal/QuartzCore)
#   rive::cg_renderer   - CoreGraphics renderer (links CoreGraphics/CoreText)
#   rive::decoders      - image decoders (PNG, JPEG, WebP)
#
# Usage:
#   find_package(rive CONFIG REQUIRED)
#   target_link_libraries(myapp PRIVATE rive::rive rive::pls_renderer)

cmake_minimum_required(VERSION 3.15)

# Resolve prefix from this file's location: <prefix>/share/rive/rive-config.cmake
get_filename_component(_RIVE_PREFIX "${CMAKE_CURRENT_LIST_DIR}/../.." ABSOLUTE)
set(_RIVE_LIBDIR  "${_RIVE_PREFIX}/lib")
set(_RIVE_INCDIR  "${_RIVE_PREFIX}/include")

# Helper: create a static imported target from a lib basename.
# lib basename "foo" maps to file "${_RIVE_LIBDIR}/libfoo.a"
macro(_rive_add_static_lib _target _libbase)
    if(NOT TARGET ${_target})
        add_library(${_target} STATIC IMPORTED GLOBAL)
        set_target_properties(${_target} PROPERTIES
            IMPORTED_LOCATION "${_RIVE_LIBDIR}/lib${_libbase}.a"
        )
    endif()
endmacro()

# ── Internal / support libraries ──────────────────────────────────────────────
_rive_add_static_lib(rive::_harfbuzz   rive_harfbuzz)
_rive_add_static_lib(rive::_sheenbidi  rive_sheenbidi)
_rive_add_static_lib(rive::_yoga       rive_yoga)
_rive_add_static_lib(rive::_miniaudio  miniaudio)

# Image format libs - premake names "libpng"/"libjpeg"/"libwebp" produce
# liblibpng.a / liblibjpeg.a / liblibwebp.a on Unix.
_rive_add_static_lib(rive::_libpng   libpng)
_rive_add_static_lib(rive::_zlib     zlib)
_rive_add_static_lib(rive::_libjpeg  libjpeg)
_rive_add_static_lib(rive::_libwebp  libwebp)

# ── rive::rive (core) ──────────────────────────────────────────────────────────
if(NOT TARGET rive::rive)
    add_library(rive::rive STATIC IMPORTED GLOBAL)
    set_target_properties(rive::rive PROPERTIES
        IMPORTED_LOCATION             "${_RIVE_LIBDIR}/librive.a"
        INTERFACE_INCLUDE_DIRECTORIES "${_RIVE_INCDIR}"
        INTERFACE_COMPILE_FEATURES    "cxx_std_17"
    )
    set_property(TARGET rive::rive APPEND PROPERTY INTERFACE_LINK_LIBRARIES
        rive::_harfbuzz
        rive::_sheenbidi
        rive::_yoga
        rive::_miniaudio
    )
endif()

# ── rive::decoders ─────────────────────────────────────────────────────────────
if(NOT TARGET rive::decoders)
    add_library(rive::decoders STATIC IMPORTED GLOBAL)
    set_target_properties(rive::decoders PROPERTIES
        IMPORTED_LOCATION "${_RIVE_LIBDIR}/librive_decoders.a"
    )
    set_property(TARGET rive::decoders APPEND PROPERTY INTERFACE_LINK_LIBRARIES
        rive::rive
        rive::_libpng
        rive::_zlib
        rive::_libjpeg
        rive::_libwebp
    )
endif()

# ── rive::pls_renderer (Metal + OpenGL GPU renderer) ──────────────────────────
if(NOT TARGET rive::pls_renderer)
    add_library(rive::pls_renderer STATIC IMPORTED GLOBAL)
    set_target_properties(rive::pls_renderer PROPERTIES
        IMPORTED_LOCATION             "${_RIVE_LIBDIR}/librive_pls_renderer.a"
        INTERFACE_INCLUDE_DIRECTORIES "${_RIVE_INCDIR}"
    )
    set_property(TARGET rive::pls_renderer APPEND PROPERTY INTERFACE_LINK_LIBRARIES
        rive::rive
    )
    if(APPLE)
        set_property(TARGET rive::pls_renderer APPEND PROPERTY INTERFACE_LINK_LIBRARIES
            "-framework Metal"
            "-framework QuartzCore"
            "-framework Foundation"
        )
    endif()
endif()

# ── rive::cg_renderer (CoreGraphics renderer, macOS / iOS) ────────────────────
if(NOT TARGET rive::cg_renderer)
    add_library(rive::cg_renderer STATIC IMPORTED GLOBAL)
    set_target_properties(rive::cg_renderer PROPERTIES
        IMPORTED_LOCATION             "${_RIVE_LIBDIR}/librive_cg_renderer.a"
        INTERFACE_INCLUDE_DIRECTORIES "${_RIVE_INCDIR}"
    )
    set_property(TARGET rive::cg_renderer APPEND PROPERTY INTERFACE_LINK_LIBRARIES
        rive::rive
    )
    if(APPLE)
        set_property(TARGET rive::cg_renderer APPEND PROPERTY INTERFACE_LINK_LIBRARIES
            "-framework CoreGraphics"
            "-framework CoreText"
            "-framework Foundation"
        )
    endif()
endif()

unset(_RIVE_PREFIX)
unset(_RIVE_LIBDIR)
unset(_RIVE_INCDIR)
