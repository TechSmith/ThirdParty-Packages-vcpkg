# Build script for Soundpipe on Windows
# Called at build time (not configure time) via ExternalProject_Add_Step or vcpkg

if(NOT SOUNDPIPE_SOURCE_DIR)
   message(FATAL_ERROR "SOUNDPIPE_SOURCE_DIR not set")
endif()

# Normalize the path and remove any quotes
string(REPLACE "\"" "" SOUNDPIPE_SOURCE_DIR "${SOUNDPIPE_SOURCE_DIR}")
file(TO_CMAKE_PATH "${SOUNDPIPE_SOURCE_DIR}" SP_ROOT)

# Verify the source directory exists
if(NOT EXISTS "${SP_ROOT}")
   message(FATAL_ERROR "Soundpipe source directory does not exist: ${SP_ROOT}")
endif()

# Find the C compiler if not specified
if(NOT CMAKE_C_COMPILER OR CMAKE_C_COMPILER STREQUAL "cl.exe")
   find_program(CMAKE_C_COMPILER_FOUND NAMES cl.exe)
   if(CMAKE_C_COMPILER_FOUND)
      set(CMAKE_C_COMPILER "${CMAKE_C_COMPILER_FOUND}")
      message(STATUS "Soundpipe: Found cl.exe at ${CMAKE_C_COMPILER}")
   else()
      set(CMAKE_C_COMPILER "cl.exe")
      message(STATUS "Soundpipe: Using cl.exe from PATH")
   endif()
endif()

# Find the archiver if not specified  
if(NOT CMAKE_AR OR CMAKE_AR STREQUAL "lib.exe")
   find_program(CMAKE_AR_FOUND NAMES lib.exe)
   if(CMAKE_AR_FOUND)
      set(CMAKE_AR "${CMAKE_AR_FOUND}")
      message(STATUS "Soundpipe: Found lib.exe at ${CMAKE_AR}")
   else()
      set(CMAKE_AR "lib.exe")
      message(STATUS "Soundpipe: Using lib.exe from PATH")
   endif()
endif()

# Define all modules from config.def.mk
# We hardcode this list instead of parsing config.mk since that file
# is generated by the Makefile system which doesn't run on Windows
set(ALL_MODULES
