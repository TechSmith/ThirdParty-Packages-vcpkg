diff --git a/src/loaders/lottie/tvgLottieExpressions.cpp b/src/loaders/lottie/tvgLottieExpressions.cpp
index d7e9a29..5d9f044 100644
--- a/src/loaders/lottie/tvgLottieExpressions.cpp
+++ b/src/loaders/lottie/tvgLottieExpressions.cpp
@@ -33,6 +33,27 @@
     #include "jerryscript-port.h"
 #endif
 
+/************************************************************************/
+/* JerryScript VM hardening                                             */
+/************************************************************************/
+
+#if JERRY_VM_HALT
+/* Instruction budget: abort after this many backward-branch ticks.     */
+/* Each tick corresponds to roughly one loop iteration or function call.*/
+#ifndef TVG_JERRY_VM_HALT_TICKS
+#define TVG_JERRY_VM_HALT_TICKS 1000000u
+#endif
+
+static uint32_t _haltCounter = 0;
+
+static jerry_value_t _vmHaltCallback(void * /*user_p*/)
+{
+    if (++_haltCounter >= TVG_JERRY_VM_HALT_TICKS)
+        return jerry_string_sz("Lottie expression execution limit exceeded");
+    return jerry_undefined();
+}
+#endif /* JERRY_VM_HALT */
+
 /************************************************************************/
 /* Internal Class Implementation                                        */
 /************************************************************************/
@@ -1466,6 +1487,10 @@ jerry_value_t LottieExpressions::evaluate(float frameNo, LottieExpression* exp)
 {
     if (exp->disabled) return jerry_undefined();
 
+#if JERRY_VM_HALT
+    _haltCounter = 0;
+#endif
+
     auto& context = this->context();
 
     buildGlobal(context, frameNo, exp);
@@ -1560,6 +1585,10 @@ LottieExpressions::Context& LottieExpressions::context()
 void LottieExpressions::init(Context& context)
 {
     jerry_init(JERRY_INIT_EMPTY);
+#if JERRY_VM_HALT
+    /* Register the halt callback so infinite loops are terminated. */
+    jerry_halt(_vmHaltCallback, nullptr, 256);
+#endif
 #ifdef THORVG_THREAD_SUPPORT
     context.ctx = jerry_port_context_get();
 #endif
