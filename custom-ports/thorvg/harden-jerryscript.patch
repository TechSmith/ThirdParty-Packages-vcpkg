+
+#if JERRY_VM_HALT
+/**
+ * Set a callback that is periodically called by the VM to decide
+ * whether execution should be aborted.
+ *
+ * If frequency is 0 the callback is disabled.
+ *
+ * @param handler   callback (return undefined to continue, anything else to abort)
+ * @param user_p    user pointer forwarded to the callback
+ * @param frequency number of backward-branch ticks between calls
+ */
+void
+jerry_halt (jerry_halt_cb_t handler,  /**< halt callback or NULL */
+            void *user_p,             /**< user pointer */
+            uint32_t frequency)       /**< call frequency (0 = disable) */
+{
+  JERRY_CONTEXT (vm_exec_stop_cb)        = (ecma_vm_exec_stop_callback_t) handler;
+  JERRY_CONTEXT (vm_exec_stop_user_p)    = user_p;
+  JERRY_CONTEXT (vm_exec_stop_frequency) = frequency;
+  JERRY_CONTEXT (vm_exec_stop_counter)   = frequency;
+} /* jerry_halt */
+#endif /* JERRY_VM_HALT */
