diff --git a/CMakeLists.txt b/CMakeLists.txt
index 36eef350..1d29f6df 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -77,6 +77,12 @@ option(WHISPER_BUILD_TESTS    "whisper: build tests"          ${WHISPER_STANDALO
 option(WHISPER_BUILD_EXAMPLES "whisper: build examples"       ${WHISPER_STANDALONE})
 option(WHISPER_BUILD_SERVER   "whisper: build server example" ${WHISPER_STANDALONE})
 
+# CPU instruction set options
+option(WHISPER_AVX    "whisper: enable AVX intrinsics"    ON)
+option(WHISPER_AVX2   "whisper: enable AVX2 intrinsics"   ON)
+option(WHISPER_AVX512 "whisper: enable AVX512 intrinsics" OFF)
+option(WHISPER_FMA    "whisper: enable FMA intrinsics"    ON)
+
 # 3rd party libs
 option(WHISPER_CURL "whisper: use libcurl to download model from an URL" OFF)
 option(WHISPER_SDL2 "whisper: support for libSDL2" OFF)
@@ -137,6 +143,48 @@ if (NOT TARGET ggml)
         add_library(ggml ALIAS ggml::ggml)
     else()
         add_subdirectory(ggml)
+        
+        # Debug: Show GGML CPU instruction set flags after ggml subdirectory is processed
+        message(STATUS "GGML CPU instruction set configuration (after ggml processing):")
+        message(STATUS "  GGML_AVX: ${GGML_AVX}")
+        message(STATUS "  GGML_AVX2: ${GGML_AVX2}")
+        message(STATUS "  GGML_AVX512: ${GGML_AVX512}")
+        message(STATUS "  GGML_AVX512_VBMI: ${GGML_AVX512_VBMI}")
+        message(STATUS "  GGML_AVX512_VNNI: ${GGML_AVX512_VNNI}")
+        message(STATUS "  GGML_AVX512_BF16: ${GGML_AVX512_BF16}")
+        message(STATUS "  GGML_FMA: ${GGML_FMA}")
+        message(STATUS "  GGML_F16C: ${GGML_F16C}")
+        
+        # Re-apply overrides after ggml subdirectory processing (in case ggml changed them)
+        if (NOT WHISPER_AVX)
+            set(GGML_AVX OFF CACHE BOOL "Disable AVX" FORCE)
+        endif()
+        if (NOT WHISPER_AVX2)
+            set(GGML_AVX2 OFF CACHE BOOL "Disable AVX2" FORCE)
+            set(GGML_FMA OFF CACHE BOOL "Disable FMA" FORCE)
+            set(GGML_F16C OFF CACHE BOOL "Disable F16C" FORCE)
+        endif()
+        if (NOT WHISPER_AVX512)
+            set(GGML_AVX512 OFF CACHE BOOL "Disable AVX512" FORCE)
+            set(GGML_AVX512_VBMI OFF CACHE BOOL "Disable AVX512-VBMI" FORCE)
+            set(GGML_AVX512_VNNI OFF CACHE BOOL "Disable AVX512-VNNI" FORCE)
+            set(GGML_AVX512_BF16 OFF CACHE BOOL "Disable AVX512-BF16" FORCE)
+        endif()
+        if (NOT WHISPER_FMA)
+            set(GGML_FMA OFF CACHE BOOL "Disable FMA" FORCE)
+        endif()
+        
+        # Debug: Show final values after re-applying overrides
+        message(STATUS "GGML CPU instruction set configuration (final):")
+        message(STATUS "  GGML_AVX: ${GGML_AVX}")
+        message(STATUS "  GGML_AVX2: ${GGML_AVX2}")
+        message(STATUS "  GGML_AVX512: ${GGML_AVX512}")
+        message(STATUS "  GGML_AVX512_VBMI: ${GGML_AVX512_VBMI}")
+        message(STATUS "  GGML_AVX512_VNNI: ${GGML_AVX512_VNNI}")
+        message(STATUS "  GGML_AVX512_BF16: ${GGML_AVX512_BF16}")
+        message(STATUS "  GGML_FMA: ${GGML_FMA}")
+        message(STATUS "  GGML_F16C: ${GGML_F16C}")
+        
         if(WIN32)
             # The following adds a _DISABLE_CONSTEXPR_MUTEX_CONSTRUCTOR macro and is a workaround for
             # the Windows C++ standard library which does not support constexpr mutexes.
diff --git a/ggml/src/CMakeLists.txt b/ggml/src/CMakeLists.txt
index 9cb2c228..27abbfc3 100644
--- a/ggml/src/CMakeLists.txt
+++ b/ggml/src/CMakeLists.txt
@@ -187,7 +187,7 @@ if (GGML_BACKEND_DL AND NOT BUILD_SHARED_LIBS)
     message(FATAL_ERROR "GGML_BACKEND_DL requires BUILD_SHARED_LIBS")
 endif()
 
-add_library(ggml-base
+add_library(ggml-base STATIC
             ../include/ggml.h
             ../include/ggml-alloc.h
             ../include/ggml-backend.h
@@ -210,7 +210,7 @@ if (GGML_BACKEND_DL)
     target_compile_definitions(ggml-base PUBLIC GGML_BACKEND_DL)
 endif()
 
-add_library(ggml
+add_library(ggml STATIC
             ggml-backend-reg.cpp)
 add_library(ggml::ggml ALIAS ggml)
 
@@ -229,15 +229,16 @@ function(ggml_add_backend_library backend)
         add_dependencies(ggml ${backend})
         install(TARGETS ${backend} LIBRARY DESTINATION ${CMAKE_INSTALL_BINDIR})
     else()
-        add_library(${backend} ${ARGN})
+        # Force STATIC build for all ggml backend libraries
+        add_library(${backend} STATIC ${ARGN})
         target_link_libraries(ggml PUBLIC ${backend})
-        install(TARGETS ${backend} LIBRARY)
+        install(TARGETS ${backend} ARCHIVE)
     endif()
 
     target_link_libraries(${backend} PRIVATE ggml-base)
     target_include_directories(${backend} PRIVATE ..)
 
-    if (${BUILD_SHARED_LIBS})
+    if (FALSE)  # Never build ggml backends as shared libraries
         target_compile_definitions(${backend} PRIVATE GGML_BACKEND_BUILD)
         target_compile_definitions(${backend} PUBLIC  GGML_BACKEND_SHARED)
     endif()
@@ -395,7 +396,10 @@ if(CMAKE_SYSTEM_NAME MATCHES "visionOS")
     target_compile_definitions(ggml-base PUBLIC _DARWIN_C_SOURCE)
 endif()
 
-if (BUILD_SHARED_LIBS)
+# Force static build for ggml components even when BUILD_SHARED_LIBS is ON
+# This ensures whisper.dll includes all ggml code statically
+# Do NOT define GGML_SHARED when building statically
+if (FALSE)  # Never build ggml as shared libraries
     foreach (target ggml-base ggml)
         set_target_properties(${target} PROPERTIES POSITION_INDEPENDENT_CODE ON)
         target_compile_definitions(${target} PRIVATE GGML_BUILD)
