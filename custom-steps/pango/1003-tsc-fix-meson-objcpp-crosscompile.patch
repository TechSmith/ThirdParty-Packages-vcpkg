@@ -11,8 +11,8 @@ pkg-config = ['@PKGCONFIG@']
 @MESON_CXX_LD@
 @MESON_OBJC@
 @MESON_OBJC_LD@
-@MESON_OBJCPP@
-@MESON_OBJCPP_LD@
+@MESON_OBJCXX@
+@MESON_OBJCXX_LD@
 @MESON_FC@
 @MESON_FC_LD@
 @MESON_WINDRES@
@@ -36,7 +36,7 @@ werror = false
 @MESON_CXXFLAGS@
 @MESON_FCFLAGS@
 @MESON_OBJCFLAGS@
